# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/edunovas

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq AI API Key (Required)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# JWT Secret Key (Required)
# Generate a secure random string
JWT_SECRET_KEY=your_secure_jwt_secret_key_here

# API Security
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=10485760

# Ollama Configuration (Optional - for local LLM)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:latest

# OpenAI API Key (Optional - for Supabase Studio AI features)
OPENAI_API_KEY=sk_your_openai_key_here

# Teacher RAG Retrieval (Optional)
# hash avoids loading Torch/SentenceTransformer during live requests.
# Use sentence-transformers only if you specifically want the heavier semantic model.
RAG_EMBEDDING_BACKEND=hash
RAG_EMBEDDING_DIMENSION=384
RAG_VECTOR_BACKEND=numpy
RAG_CONTEXT_TIMEOUT_SECONDS=35

# Neo4j Teacher Flow Graphs (Optional)
# Offline Docker only. No remote Neo4j/Aura URI is accepted while NEO4J_OFFLINE_ONLY=true.
# Backend running on Windows host: bolt://localhost:7687
# Backend inside Docker Compose: bolt://neo4j:7687
NEO4J_OFFLINE_ONLY=true
NEO4J_ALLOWED_HOSTS=localhost,127.0.0.1,::1,neo4j,host.docker.internal
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Interview Memory Vector Store (Optional)
# Uses FAISS for candidate interview-answer memory and stores artifacts in Supabase Storage.
INTERVIEW_VECTOR_BACKEND=faiss
INTERVIEW_VECTOR_BUCKET=rag-vectors
INTERVIEW_VECTOR_PREFIX=interview-memory
INTERVIEW_EMBEDDING_DIMENSION=384

# S3 Configuration (Optional - for OrioleDB)
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
